# ── HomeLog backend configuration ────────────────────────────────────────────
# Copy this file to `.env`. NEVER commit `.env`.
#
# The app runs with ZERO setup: if MONGO_URI is left blank, an in-memory MongoDB
# is started automatically and seeded with the demo account on every boot.
# (That data is ephemeral — it resets when the server stops.)
#
# To persist data, set MONGO_URI to a real database:
#   Local:  mongodb://127.0.0.1:27017/homelog
#   Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/homelog?retryWrites=true&w=majority
MONGO_URI=

# Secret used to sign JWTs. A dev default is used if blank; set a long, random
# value in production (required there).
JWT_SECRET=change-me-to-a-long-random-string

# How long issued tokens stay valid (zeit/ms format).
JWT_EXPIRES=7d

# Port the API listens on.
PORT=5000

# Comma-separated list of allowed CORS origins. Use * to allow any (dev only).
CORS_ORIGIN=*

# Node environment: development | test | production
NODE_ENV=development
